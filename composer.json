{
    "name": "studip/core",
    "description": "Stud.IP ist ein Campus- und Lernmanagementsystem für Hochschulen, Schulen, Unternehmen, Verbände und Behörden.",
    "config": {
        "vendor-dir": "composer",
        "platform": {
            "php": "8.1"
        }
