        "symfony/process": "6.4.7",
        "jumbojett/openid-connect-php": "1.0.0",
        "league/oauth2-server": "8.5.4",
        "willdurand/negotiation": "^3.1",
        "monolog/monolog": "^2.8",
        "ksubileau/color-thief-php": "^2.0",
