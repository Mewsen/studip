            "Studip\\Middleware\\": "lib/middleware/",
            "Studip\\Plugins\\": "lib/plugins/core/",
            "Studip\\Session\\": "lib/session/",
            "Studip\\Authentication\\": "lib/authentication/",
            "Trails\\": "lib/trails/",
            "": [
                "lib/classes/",
                "lib/classes/admission/",
