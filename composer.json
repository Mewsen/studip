                "lib/filesystem/",
                "lib/ilias_interface",
                "lib/migrations/",
                "lib/models/",
                "lib/models/calendar/",
                "lib/models/resources/",
                "lib/models/vips/",
                "lib/modules/",
                "lib/navigation/",
                "lib/plugins/core/",
                "lib/plugins/db/",
                "lib/plugins/engine/",
                "lib/resources/"
